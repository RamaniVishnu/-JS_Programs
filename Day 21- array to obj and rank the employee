1)Competition Ranking
const competitionRanking = data => {

    let rank = 1;
    let prevScore = null;

    return data.map(([name, score]) => ({ name, score }))
        .sort((a, b) => b.score - a.score)
        .map((emp, index) => {

            if (
                prevScore !== null &&
                emp.score < prevScore
            ) {
                rank = index + 1;
            }

            prevScore = emp.score;

            return {
                ...emp,
                rank
            };
        });
};

console.log(competitionRanking(arr));

