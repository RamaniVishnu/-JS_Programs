const denseRanking = data => {

    let rank = 1;
    let prevScore = null;

    return data.map(([name, score]) => ({ name, score }))
        .sort((a, b) => b.score - a.score)
        .map(emp => {

            if (
                prevScore !== null &&
                emp.score < prevScore
            ) {
                rank++;
            }

            prevScore = emp.score;

            return {
                ...emp,
                rank
            };
        });
};

