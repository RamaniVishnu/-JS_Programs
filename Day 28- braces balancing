function hasEqualOpenCloseCounts(input) {
  const counts = {
    '(': 0,
    ')': 0,
    '{': 0,
    '}': 0,
    '[': 0,
    ']': 0
  };

  for (let char of input) {
    if (counts.hasOwnProperty(char)) {
      counts[char]++;
    }
  }

  return (
    counts['('] === counts[')'] &&
    counts['{'] === counts['}'] &&
    counts['['] === counts[']']
  );
}
const test1 = "[{]}{}"; // true (matching counts)
const test2 = "[{{}]";  // false (mismatched counts)
console.log(hasEqualOpenCloseCounts(test1)); // true


//enhanced code
const hasEqualOpenCloseCounts = input => {
    const pairs = {
        '(': ')',
        '{': '}',
        '[': ']'
    };
    const counts = {};
    // Initialize counts
    for (const bracket of Object.keys(pairs)) {
        counts[bracket] = 0;
        counts[pairs[bracket]] = 0;
    }
    // Count brackets
    for (const char of input) {

        if (char in counts) {
            counts[char]++;
        }
    }
    // Validate counts
    return Object.entries(pairs)
        .every(([open, close]) =>
            counts[open] === counts[close]
        );
};
