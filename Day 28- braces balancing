//code using Set
const isBalancedBrackets = str => {
    const pairs = {
        ')': '(',
        '}': '{',
        ']': '['
    };
    const openings = new Set(['(', '{', '[']);
    const stack = [];
    for (const char of str) {
        if (openings.has(char)) {
            stack.push(char);
        }
        else if (char in pairs) {

            if (stack.pop() !== pairs[char]) {
                return false;
            }
        }
    }
    return stack.length === 0;
};


